msgid "Form choice has no name\n"
msgstr "У выбора формы нет названия\n"

#: auth.c:203
#, c-format
msgid "name %s not input\n"
msgstr "назовите %s, а не ввод\n"

#: auth.c:210
msgid "No input type in form\n"
msgstr "В форме нет типа вводных данных\n"

#: auth.c:222
msgid "No input name in form\n"
msgstr "В форме нет имени вводных данных\n"

#: auth.c:257
#, c-format
msgid "Unknown input type %s in form\n"
msgstr "Неизвестный тип ввода %s в форме\n"

