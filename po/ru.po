msgstr "Пустой ответ от сервера\n"

#: auth.c:612
msgid "Failed to parse server response\n"
msgstr "Не удалось проанализировать ответ сервера\n"

#: auth.c:614 f5.c:422 f5.c:464 f5.c:489 f5.c:634 fortinet.c:445 fortinet.c:631
#, c-format
msgid "Response was:%s\n"
msgstr "Ответ был:%s\n"

#: auth.c:636
msgid "Received <client-cert-request> when not expected.\n"
msgstr "Получен <client-cert-request>, когда он не ожидался.\n"

#: auth.c:645
msgid "Received <multiple-client-cert-request> when not expected.\n"
msgstr "Получен <multiple-client-cert-request>, когда он не ожидался.\n"

#: auth.c:682
#, c-format
