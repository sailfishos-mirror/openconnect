msgstr "Отказ для туннелей UDP без использования DTLS\n"

#: array.c:777
msgid "Failed to read ipff response\n"
msgstr "Не удалось прочитать ответ ipff\n"

#: array.c:831 array.c:1119 array.c:1229 cstp.c:970 dtls.c:283 dtls.c:643
#: esp.c:155 gpst.c:1181 mainloop.c:63 oncp.c:921 ppp.c:1089 ppp.c:1676
#: pulse.c:2841
msgid "Allocation failed\n"
msgstr "Сбой выделения памяти\n"

#: array.c:846
#, c-format
msgid "Received %d more bytes after partial %d\n"
msgstr "Получено ещё %d байтов после неполных %d\n"

#: array.c:860
#, c-format
msgid "Received partial packet, %d bytes\n"
msgstr "Получен неполный пакет, байтов: %d\n"

#: array.c:875
#, c-format
msgid "Unrecognised data packet, len %d\n"
msgstr "Нераспознанный пакет данных, длина: %d\n"

#: array.c:886
#, c-format
msgid "Received partial packet, %d of %d bytes\n"
msgstr "Получен неполный пакет, %d из %d байтов\n"

#: array.c:896 array.c:1256
#, c-format
msgid "Receive control packet of type %x:\n"
msgstr "Получение контрольного пакета с типом %x:\n"

#: array.c:903 pulse.c:2886
#, c-format
msgid "Received data packet of %d bytes\n"
msgstr "Получен пакет данных, байтов: %d\n"

#: array.c:924
#, c-format
msgid "Moved down %d bytes after previous packet\n"
msgstr "%d байтов перемещены ниже предыдущего пакета\n"

#: array.c:961 cstp.c:1111 gpst.c:1283 oncp.c:1135 ppp.c:1376 pulse.c:3021
#, c-format
msgid "SSL wrote too few bytes! Asked for %d, sent %d\n"
msgstr "SSL записал слишком мало байтов. Запрошено: %d, отправлено %d\n"

#. Not that this will ever happen; we don't even process
#. the setting when we're asked for it.
#: array.c:979 cstp.c:1139 oncp.c:1172 pulse.c:3048
msgid "CSTP rekey due\n"
msgstr "Необходима замена ключей CSTP\n"

#. if we failed rehandshake try establishing a new-tunnel instead of failing
#: array.c:986 cstp.c:1146 oncp.c:1179 pulse.c:3055
msgid "Rehandshake failed; attempting new-tunnel\n"
msgstr ""
"Сбой повторного согласования handshake; попытка создания нового тоннеля\n"

#: array.c:996
msgid "TCP Dead Peer Detection detected dead peer!\n"
msgstr "Обнаружение нерабочих пиров TCP: обнаружен нерабочий пир.\n"

#: array.c:1000
msgid "TCP reconnect failed\n"
msgstr "Сбой повторного подключения TCP\n"

#: array.c:1016
msgid "Send TCP DPD\n"
msgstr "Отправить TCP DPD\n"

#: array.c:1033
msgid "Send TCP Keepalive\n"
msgstr "Отправить TCP Keepalive\n"

#: array.c:1049
msgid "Sending DTLS off packet\n"
msgstr "Отправляется пакет выключения DTLS\n"

#: array.c:1059 cstp.c:1225 oncp.c:1257
#, c-format
msgid "Sending uncompressed data packet of %d bytes\n"
msgstr "Отправляется пакет с несжатыми данными, байт: %d\n"

#: array.c:1097 dtls.c:259 ppp.c:1790
msgid "Attempt new DTLS connection\n"
msgstr "Попытка создания нового подключения DTLS\n"

#: array.c:1131 ppp.c:1688
msgid "Failed to receive authentication response from DTLS\n"
msgstr "Не удалось получить ответ аутентификации от DTLS\n"

#: array.c:1143
msgid "DTLS session established\n"
msgstr "Сеанс DTLS установлен\n"

#: array.c:1156
msgid "Received Legacy IP over DTLS; assuming established\n"
msgstr ""
"С использованием DTLS получен IP в старом формате; считаем, что сеанс "
"установлен\n"

#: array.c:1164
msgid "Received IPv6 over DTLS; assuming established\n"
msgstr "С использованием DTLS получен IPv6; считаем, что сеанс установлен\n"

#: array.c:1170
msgid "Received unknown DTLS packet\n"
msgstr "Получен неизвестный пакет DTLS\n"

#: array.c:1178 ppp.c:1742
msgid "Error creating connect request for DTLS session\n"
msgstr "Ошибка создания запроса на подключение для сеанса DTLS\n"

#: array.c:1194 ppp.c:1758
msgid "Failed to write connect request to DTLS session\n"
msgstr "Не удалось записать запрос на подключение в сеанс DTLS\n"

#: array.c:1247 dtls.c:294
#, c-format
msgid "Received DTLS packet 0x%02x of %d bytes\n"
msgstr "Получен пакет DTLS 0x%02x из %d байт\n"

#: array.c:1271 dtls.c:358
msgid "DTLS rekey due\n"
msgstr "Необходима замена ключей DTLS\n"

#: array.c:1278 dtls.c:365
msgid "DTLS Rehandshake failed; reconnecting.\n"
msgstr ""
"Сбой повторного согласования (handshake) DTLS; выполняется повторное "
"подключение.\n"

#: array.c:1287 dtls.c:374
msgid "DTLS Dead Peer Detection detected dead peer!\n"
msgstr "Обнаружение нерабочих пиров DTLS: обнаружен нерабочий пир.\n"

#: array.c:1293 dtls.c:380
msgid "Send DTLS DPD\n"
msgstr "Отправка DTLS DPD\n"

#: array.c:1297 dtls.c:385
msgid "Failed to send DPD request. Expect disconnect\n"
msgstr "Не удалось отправить запрос DPD. Ожидайте прерывания подключения\n"

#: array.c:1336 dtls.c:452
#, c-format
msgid "Sent DTLS packet of %d bytes; DTLS send returned %d\n"
msgstr "Отправлен пакет DTLS размером %d байт; DTLS send вернул %d\n"

#: array.c:1362 auth-globalprotect.c:887 f5.c:862 fortinet.c:892 oncp.c:1285
msgid "Logout failed.\n"
msgstr "Сбой выхода\n"

#: array.c:1364 auth-globalprotect.c:889 f5.c:864 fortinet.c:894 oncp.c:1287
msgid "Logout successful.\n"
msgstr "Выход успешно выполнен.\n"

#: auth-globalprotect.c:103
msgid ""
"SAML authentication required; using portal-userauthcookie to continue SAML.\n"
msgstr ""
"Требуется аутентификация SAML; для продолжения SAML используется portal-"
"userauthcookie.\n"

#: auth-globalprotect.c:105
msgid ""
"SAML authentication required; using portal-prelogonuserauthcookie to "
"continue SAML.\n"
msgstr ""
"Требуется аутентификация SAML; для продолжения SAML используется portal-"
"prelogonuserauthcookie.\n"

#: auth-globalprotect.c:107
#, c-format
msgid ""
"Destination form field %s was specified; assuming SAML %s authentication is "
"complete.\n"
msgstr ""
"Было указано поле формы назначения %s; считаем, что аутентификация SAML %s "
"выполнена.\n"

#: auth-globalprotect.c:147
#, c-format
msgid "SAML %s authentication is required via %s\n"
msgstr "Требуется аутентификация SAML %s с помощью %s\n"

#: auth-globalprotect.c:153
msgid ""
"When SAML authentication is complete, specify destination form field by "
"appending field_name to login URL.\n"
msgstr ""
"По завершении аутентификации SAML указать поле формы назначения, добавив "
"field_name в конец адреса URL для входа в систему.\n"

#: auth-globalprotect.c:167
msgid "Please enter your username and password"
msgstr "Укажите имя пользователя и пароль"

#: auth-globalprotect.c:178
msgid "Username"
msgstr "Имя пользователя"

#: auth-globalprotect.c:195
msgid "Password"
msgstr "Пароль"

#: auth-globalprotect.c:265
msgid "Challenge: "
msgstr "Вызов (challenge): "

#: auth-globalprotect.c:368
#, c-format
msgid "GlobalProtect login returned unexpected argument value arg[%d]=%s\n"
msgstr ""
"Вход в систему GlobalProtect вернул непредвиденное значение аргумента "
"arg[%d]=%s\n"

#: auth-globalprotect.c:374
#, c-format
msgid "GlobalProtect login returned %s=%s (expected %s)\n"
msgstr "Вход в систему GlobalProtect вернул %s=%s (ожидалось %s)\n"

#: auth-globalprotect.c:380
#, c-format
msgid "GlobalProtect login returned empty or missing %s\n"
msgstr "Вход в систему GlobalProtect вернул пустой или отсутствующий %s\n"

#: auth-globalprotect.c:384
#, c-format
msgid "GlobalProtect login returned %s=%s\n"
msgstr "Вход в систему GlobalProtect вернул %s=%s\n"

#: auth-globalprotect.c:398
#, c-format
msgid "Please report %d unexpected values above (of which %d fatal) to <%s>\n"
msgstr ""
"Пожалуйста, сообщите о непредвиденных %d значениях выше (из которых "
"критических %d), в <%s>\n"

#: auth-globalprotect.c:447
msgid "Please select GlobalProtect gateway."
msgstr "Выберите шлюз GlobalProtect."

#: auth-globalprotect.c:457
msgid "GATEWAY:"
msgstr "ШЛЮЗ:"

#: auth-globalprotect.c:504
#, c-format
msgid ""
"Ignoring portal's HIP report interval (%d minutes), because interval is "
"already set to %d minutes.\n"
msgstr ""
"Интервал (%d мин.) отчётов сканирования HIP портала игнорируется, т.к. для "
"этого интервала уже было настроено значение в %d мин.\n"

#: auth-globalprotect.c:508
#, c-format
msgid "Portal set HIP report interval to %d minutes).\n"
msgstr "Портал настроил значение интервала сканирований HIP в %d мин.).\n"

#. We abuse csd_ticket to store the portal's software version. Parroting this back as
#. * the client software version (app-version) appears to be the best way to prevent the
#. * gateway server from rejecting the connection due to obsolete client software.
#.
#: auth-globalprotect.c:518
#, c-format
msgid ""
"Portal reports GlobalProtect version %s; we will report the same client "
"version.\n"
msgstr ""
"Портал сообщает, что версия GlobalProtect равна %s; мы сообщим такую же "
"версию клиента.\n"

#: auth-globalprotect.c:541
msgid "GlobalProtect portal configuration lists no gateway servers.\n"
msgstr "В конфигурации GlobalProtect отсутствуют серверы шлюзов.\n"

#: auth-globalprotect.c:550 main.c:1653
msgid "unknown"
msgstr "неизвестно"

#. Each entry looks like:
#. *   <entry name="host[:443]">
#. *     <description>Label</description>
#. *     <priority-rule>           <!-- This is optional -->
#. *       <entry name="US"><priority>1</priority></entry>
#. *       <entry name="DE"><priority>2</priority></entry>
#. *       <entry name="Any"><priority>3</priority></entry>
#. *     </priority-rule>
#. *   </entry>
#.
#: auth-globalprotect.c:578
#, c-format
msgid "%d gateway servers available:\n"
msgstr "доступно серверов шлюзов: %d: \n"

#: auth-globalprotect.c:616
#, c-format
msgid "  %s (%s) [priority %d]\n"
msgstr "  %s (%s) [приоритет %d]\n"

#: auth-globalprotect.c:619
#, c-format
msgid "  %s (%s) [unprioritized]\n"
msgstr "  %s (%s) [без приоритета]\n"

