msgstr ""
"Не удалось создать код маркёра OTP; использование маркёра отключается\n"

#: auth-globalprotect.c:835
msgid "Server is neither a GlobalProtect portal nor a gateway.\n"
msgstr "Сервер не является ни порталом GlobalProtect, ни шлюзом.\n"

