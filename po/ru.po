msgstr "Непредвиденный ответ на запрос протокола Array в формате JSON\n"

#: array.c:579
msgid "Failed to parse Array JSON response\n"
msgstr "Сбой анализа ответа в формате JSON протокола Array\n"

#: array.c:659
msgid "Error creating array negotiation request\n"
msgstr "Ошибка создания запроса на согласование array\n"

#: array.c:675 f5.c:827 http.c:987 oncp.c:515 pulse.c:1400
#, c-format
